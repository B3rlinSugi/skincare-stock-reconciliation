# .env.example
# Panduan Environment Variables untuk Produksi (Vercel / Node.js)

# 1. Supabase URL (Akses Publik API)
# Didapatkan dari: Supabase Dashboard -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# 2. Supabase Anon Key (Kunci Anonim)
# Didapatkan dari: Supabase Dashboard -> Settings -> API -> Project API Keys (anon, public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUz... (masukkan token anonim di sini)

# 3. Supabase Service Role Key (Kunci Bypass RLS - Rahasia Server)
# SANGAT RAHASIA: JANGAN PERNAH MENGEKSPOS KEY INI KE FRONTEND
# Didapatkan dari: Supabase Dashboard -> Settings -> API -> Project API Keys (service_role, secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUz... (masukkan token service_role di sini)

# Opsional: Jika menggunakan Sentry di masa mendatang, tambahkan token Auth Sentry
# SENTRY_AUTH_TOKEN=
